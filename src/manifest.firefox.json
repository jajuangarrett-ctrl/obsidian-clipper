{
	"manifest_version": 3,
	"default_locale": "en",
	"name": "FJG Obsidian Task Clipper",
	"homepage_url": "https://github.com/jajuangarrett-ctrl/obsidian-clipper",
	"version": "0.1.0",
	"description": "Create Obsidian #task lines from selected browser text with status and project choices.",
	"permissions": [
		"activeTab",
		"clipboardWrite",
		"contextMenus",
		"storage",
		"scripting",
		"webRequest",
		"webRequestBlocking"
	],
	"host_permissions": [
		"<all_urls>",
		"http://*/*",
		"https://*/*"
	],
	"optional_host_permissions": [
		"<all_urls>"
	],
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon16.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		}
	},
	"options_ui": {
		"page": "settings.html",
		"open_in_tab": true
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"background": {
		"scripts": ["background.js"]
	},
	"content_scripts": [
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["browser-polyfill.min.js", "content.js"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["reader.css", "reader-script.js", "browser-polyfill.min.js", "style.css", "side-panel.html", "flatten-shadow-dom.js", "highlighter.css"],
			"extension_ids": ["*"],
   			"matches": [ "*://*/*" ]
		}
	],
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	},
	"commands": {
		"_execute_action": {
			"suggested_key": {
				"default": "Ctrl+Shift+F",
				"mac": "Command+Shift+F"
			},
			"description": "Open FJG Obsidian Task Clipper"
		},
		"toggle_highlighter": {
			"suggested_key": {
				"default": "Alt+Shift+H",
				"mac": "Alt+Shift+H"
			},
			"description": "__MSG_commandToggleHighlighter__"
		},
		"toggle_reader": {
			"suggested_key": {
				"default": "Alt+Shift+R",
				"mac": "Alt+Shift+R"
			},
			"description": "__MSG_commandToggleReader__"
		}
	},
	"browser_specific_settings": {
		"gecko": {
			"id": "fjg-obsidian-task-clipper@jajuangarrett-ctrl",
			"strict_min_version": "113.0",
			"data_collection_permissions": {
				"required": ["none"]
			}
		},
		"gecko_android": {
			"strict_min_version": "113.0",
			"data_collection_permissions": {
				"required": ["none"]
			}
		}
	}
}

{
	"manifest_version": 3,
	"name": "FJG Obsidian Task Clipper",
	"homepage_url": "https://github.com/jajuangarrett-ctrl/obsidian-clipper",
	"version": "0.1.0",
	"description": "Create FJG Obsidian task lines from selected Chrome text, with Taskboard statuses and project routing.",
	"permissions": [
		"activeTab",
		"clipboardWrite",
		"contextMenus",
		"storage",
		"scripting"
	],
	"host_permissions": [
		"http://*/*",
		"https://*/*"
	],
	"action": {
		"default_popup": "popup.html"
	},
	"options_ui": {
		"page": "settings.html",
		"open_in_tab": true
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"background": {
		"service_worker": "background.js"
	},
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	},
	"commands": {
		"_execute_action": {
			"suggested_key": {
				"default": "Ctrl+Shift+F",
				"mac": "Command+Shift+F"
			},
			"description": "Open FJG Obsidian Task Clipper"
		}
	}
}
